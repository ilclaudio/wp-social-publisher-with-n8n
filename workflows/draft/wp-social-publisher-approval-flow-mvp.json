      "id": "fetch-wp-posts",
      "name": "Fetch WP Posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        220
      ]
    },
    {
      "parameters": {
        "jsCode": "// Filter by WordPress publication date in UTC (date_gmt).\n// Current detection window: last 70 minutes.\nconst LOOKBACK_MINUTES = 70;\nconst now = new Date();\nconst cutoffMs = now.getTime() - LOOKBACK_MINUTES * 60 * 1000;\n\nreturn items\n  .filter((item) => {\n    const dateGmt = item.json.date_gmt;\n    if (!dateGmt) return false;\n    const publishedMs = Date.parse(`${dateGmt}Z`);\n    return Number.isFinite(publishedMs) && publishedMs > cutoffMs;\n  })\n  .map((item) => ({\n    json: {\n      ...item.json,\n      detectedAtUtc: now.toISOString(),\n    },\n  }));"
      },
      "id": "detect-new-posts",
      "name": "Detect New Posts (date_gmt)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
